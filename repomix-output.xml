DATA_ROOT_3ET = r"C:\Users\cxm3593\Academic\Workspace\Data\3ET+\3ET+ dataset\event_data"


EXAMPLE_WINDOW_SIZE = 100_000 # 100 ms

# --- Global Variables ---

